# CrewFlow - Variáveis de Ambiente (exemplo)
# NUNCA comitar valores reais. Copie este arquivo para `.env` e preencha localmente ou no servidor.

# ============================
# App (Next.js)
# ============================
# URL pública do app (inclui protocolo e porta)
NEXTAUTH_URL=
# Ambiente de execução
NODE_ENV=
# Segredo JWT da aplicação
JWT_SECRET=
# Ocultar itens de BI no menu em produção ("true" para ocultar)
NEXT_PUBLIC_HIDE_PLANEJAMENTO_BI=
# Intervalo de auto-sync de funcionários (em milissegundos)
FUNCIONARIOS_AUTO_SYNC_INTERVAL_MS=
# Token de serviço para autorizar o worker de sincronização
FUNCIONARIOS_SYNC_SERVICE_TOKEN=
# Token de serviço para rotas de manutenção (ex.: deduplicação)
MANTENCAO_SERVICE_TOKEN=
# Horários diários de sincronização (formato HH:mm, separados por vírgula)
FUNCIONARIOS_SYNC_SCHEDULE=07:00,12:30
# Alternativa: intervalo em minutos (se definido, ignora horários fixos)
FUNCIONARIOS_SYNC_INTERVAL_MINUTES=
# Timezone usado pelo worker (opcional; pode usar TZ no compose)
FUNCIONARIOS_SYNC_TIMEZONE=America/Sao_Paulo
# URL do banco de dados (Prisma)
# Formato: postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
DATABASE_URL=
# Integração RM — API externa de funcionários
# URL da consulta (ex.: https://.../RealizaConsulta/GS.INT.0005/1/P)
RM_API_URL=
# Autorização (ex.: Basic <base64>)
RM_API_AUTH=
# Credenciais do usuário administrador (usadas pelos scripts de seed)
ADMIN_USER=
ADMIN_PASSWORD=
ADMIN_EMAIL=

# ============================
# Desenvolvimento Local (Docker)
# ============================
# Use este bloco ao rodar 'docker-compose -f docker-compose.dev.yml'
# Recomenda-se criar um arquivo .env.dev com estes nomes (sem valores reais aqui)
# Exemplo de host do Postgres local via rede do compose: postgres-dev
#NEXTAUTH_URL=
#NODE_ENV=development
#JWT_SECRET=
#DATABASE_URL=
#POSTGRES_USER=
#POSTGRES_PASSWORD=
#POSTGRES_DB=
#PGADMIN_DEFAULT_EMAIL=
#PGADMIN_DEFAULT_PASSWORD=

# ============================
# Staging (PostgreSQL + pgAdmin)
# ============================
# Credenciais do Postgres (staging)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# Credenciais do pgAdmin (staging)
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=

# ============================
# GitHub Actions — Secrets esperados (Staging)
# ============================
# Configurar em: Settings > Secrets and variables > Actions
# Nomes dos secrets utilizados nos workflows de STAGING:
# - SERVER_HOST
# - SSH_PRIVATE_KEY
# - CLEANUP_ADMIN_TOKEN
# - POSTGRES_STAGING_PASSWORD
# - PGADMIN_STAGING_EMAIL
# - PGADMIN_STAGING_PASSWORD
# - STAGING_DATABASE_URL
# - JWT_SECRET_STAGING

# ============================
# GitHub Actions — Secrets esperados (Produção)
# ============================
# Nomes dos secrets utilizados nos workflows de PRODUÇÃO:
# - SERVER_HOST
# - SSH_PRIVATE_KEY
# - PRODUCTION_DATABASE_URL
# - JWT_SECRET_PRODUCTION
# - POSTGRES_PROD_DB
# - POSTGRES_PROD_USER
# - POSTGRES_PROD_PASSWORD
# - PGADMIN_PROD_EMAIL
# - PGADMIN_PROD_PASSWORD
# - PROD_SMTP_HOST
# - PROD_SMTP_PORT
# - PROD_SMTP_SECURE
# - PROD_SMTP_USER
# - PROD_SMTP_PASS
# - PROD_SMTP_FROM
# - PROD_REPORT_GENERAL_RECIPIENTS
# - PROD_REPORT_REQUEST_ALLOWED_SENDERS
# - PROD_RELATORIO_EMAIL_SERVICE_TOKEN
# - REPORT_GENERAL_API_BASE
# - REPORT_GENERAL_EMAIL_ENDPOINT
# - PROD_IMAP_HOST
# - PROD_IMAP_PORT
# - PROD_IMAP_SECURE
# - PROD_IMAP_USER
# - PROD_IMAP_PASS

# ============================
# Observações
# ============================
# - Este arquivo serve como referência. Preencha os valores conforme o ambiente.
# - Em produção e staging, os workflows geram/atualizam o arquivo '/opt/projetogran/.env' no servidor
#   com credenciais do Postgres/pgAdmin para o docker-compose. A aplicação recebe segredos via GitHub Secrets.
# - Não comitar valores reais. Mantenha apenas este .env.example versionado.

# Ambiente da aplicação
EXCEL_PROTECT_PASSWORD=
# Proteção de planilhas Excel (ExcelJS)
# Senha usada para proteger as abas no export XLSX.
# Opcional; se não definida, usa string vazia (sem senha).

# Retenção de relatórios de importação (em dias)
# Usado para limpar automaticamente arquivos em public/import-reports no servidor
IMPORT_REPORTS_RETENTION_DAYS=30

# ============================
# E-mail SMTP e relatórios automáticos
# ============================
# Conta remetente sugerida: crewcontrol@granhub.com.br
SMTP_HOST=granhub.com.br
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Destinatários separados por vírgula
REPORT_GENERAL_RECIPIENTS=
# Token forte usado para acionar /api/relatorios/geral/enviar-email por automação
RELATORIO_EMAIL_SERVICE_TOKEN=

# ============================
# Solicitação de relatório por resposta de e-mail
# ============================
# Se vazio, usa REPORT_GENERAL_RECIPIENTS como lista de remetentes autorizados.
REPORT_REQUEST_ALLOWED_SENDERS=
REPORT_REQUEST_KEYWORD=relatorio
REPORT_REQUEST_MAX_PER_RUN=5
REPORT_REQUEST_MAX_PER_SENDER_PER_RUN=1
IMAP_HOST=granhub.com.br
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASS=
